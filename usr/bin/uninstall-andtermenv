#!/system/bin/sh
if [ -z "$1" ]; then
echo -e "\033[31mError: path cannot be empty\033[0m";exit 1
fi
if [ ! -e "$1" ]; then
echo -e "\033[31mError: path does not exist → $1\033[0m";exit 1
fi
if [ ! -f "$1" ]; then
echo -e "\033[31mError: This is not a file → $1\033[0m";exit 1
fi
if [ ! -w "$1" ]; then
echo -e "\033[31mError: File is not writable → $1\033[0m";exit 1
fi
sed -i '/^# ===andterm_env===/,/^# ---andterm_env---/d' "$1"
echo -e "\033[93mEnvironment variable configuration has been removed\033[0m"