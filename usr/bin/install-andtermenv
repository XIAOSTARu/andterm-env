#!/system/bin/sh
MODDIR=/data/adb/andtermenv
if [ -z "$1" ]; then
echo -e "\033[31mError: path cannot be empty\033[0m";exit 1
fi
if [ ! -e "$1" ]; then
echo -e "\033[31mError: path does not exist → $1\033[0m";exit 1
fi
if [ ! -f "$1" ]; then
echo -e "\033[31mError: This is not a file → $1\033[0m";exit 1
fi
if [ ! -w "$1" ]; then
echo -e "\033[31mError: File is not writable → $1\033[0m";exit 1
fi
echo "
# ===andterm_env===
export PATH=${MODDIR}/usr/bin:\$PATH
export LD_LIBRARY_PATH=${MODDIR}/usr/lib:\$LD_LIBRARY_PATH
export HOME=/data/adb/andtermenv/home
if [ \$(id -u) -ne 0 ];then
su -c version-andtermenv;su;fi
# ---andterm_env---
" >> "$1"
echo -e "\033[92mEnvironment variable configuration has been added.\033[0m"